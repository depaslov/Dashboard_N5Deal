# =============================================================================
# N5Deal Dashboard — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the values.
# See ../LOCAL_SETUP.md for full instructions.
# =============================================================================

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/n5deal_dashboard?schema=public"

# NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32"
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# Abacus.AI — used for both Content Studio generation AND RAG (LLM + embeddings)
# RouteLLM exposes the OpenAI-compatible /v1 format, so we point our OpenAI
# client at it via base URL override.
# =============================================================================
ABACUSAI_API_KEY="your-abacus-ai-key-here"
# Optional overrides:
# ABACUSAI_BASE_URL="https://routellm.abacus.ai/v1"
# ABACUSAI_LLM_MODEL="gpt-4o-mini"
# ABACUSAI_EMBEDDINGS_MODEL="text-embedding-3-small"

# =============================================================================
# Embeddings — default is local Ollama (free, offline). To use OpenAI instead
# (faster, paid), set EMBEDDINGS_PROVIDER=openai and OPENAI_API_KEY.
# =============================================================================
# EMBEDDINGS_PROVIDER="ollama"   # ollama (default) | openai | abacus
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_EMBEDDINGS_MODEL="nomic-embed-text"

# OPENAI_API_KEY="sk-..."
# OPENAI_EMBEDDINGS_MODEL="text-embedding-3-small"
