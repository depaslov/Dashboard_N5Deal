# =============================================================================
# N5Deal Dashboard — PRODUCTION env template for the Hostinger VPS
# =============================================================================
# Copy to `.env` on the VM and fill in real values. NEVER commit the populated
# .env — it's in .gitignore. Keep a copy in your password manager.
#
# Differences from local .env (.env.example):
#   - NEXTAUTH_URL must be the real https://… domain
#   - OBSIDIAN_VAULT_ROOT is fixed at /var/obsidian-vaults (container mount)
#   - OBSIDIAN_VAULTS_HOST_PATH controls where docker-compose mounts FROM the
#     VM filesystem; default /opt/n5deal/obsidian-vaults matches setup-vm.sh
# =============================================================================

# ── Database (Neon) ─────────────────────────────────────────────────────────
# Keep using the production Neon URL. Rotate the password every quarter and
# whenever a developer leaves the project.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.aws.neon.tech/neondb?sslmode=require"

# ── NextAuth (auth) ─────────────────────────────────────────────────────────
# CRITICAL: NEXTAUTH_URL must EXACTLY match the public URL — protocol,
# subdomain, no trailing slash. NextAuth signs callback URLs against this;
# mismatch produces silent login failures with no useful error.
NEXTAUTH_URL="https://dash.your-domain.com"
NEXTAUTH_SECRET="GENERATE_ME: openssl rand -base64 32"

# ── Abacus.AI (content generation + RAG embeddings) ─────────────────────────
ABACUSAI_API_KEY="your-abacus-ai-key"
# Optional overrides (defaults are baked into lib/*):
# ABACUSAI_BASE_URL="https://routellm.abacus.ai/v1"
# ABACUSAI_LLM_MODEL="gpt-4o-mini"
# ABACUSAI_EMBEDDINGS_MODEL="text-embedding-3-small"

# ── Embeddings provider ─────────────────────────────────────────────────────
# Production default is OpenAI's text-embedding-3-small via Abacus router.
# To use a local Ollama instead, expose 11434 from another container and
# point OLLAMA_BASE_URL at it — but Hostinger 4GB VPS is tight for that.
# EMBEDDINGS_PROVIDER="abacus"   # abacus (default) | openai | ollama
# OPENAI_API_KEY=""
# OLLAMA_BASE_URL=""

# ── Obsidian vault ──────────────────────────────────────────────────────────
# Container-side mount point — the app code reads from here. Leave as-is
# unless you also rewrite the Docker mount in docker-compose.yml.
OBSIDIAN_VAULT_ROOT="/var/obsidian-vaults"

# Host-side path where the VM keeps the vault. docker-compose mounts THIS
# directory INTO the container at OBSIDIAN_VAULT_ROOT. Default matches what
# setup-vm.sh creates; only change if you keep vaults somewhere else.
OBSIDIAN_VAULTS_HOST_PATH="/opt/n5deal/obsidian-vaults"

# ── Optional: anthropic direct (only if you've enabled the direct path) ─────
# ANTHROPIC_API_KEY=""
# CLAUDE_MODEL=""

# ── Optional: Google OAuth (only if you've enabled Google sign-in) ──────────
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_REDIRECT_URI="https://dash.your-domain.com/api/auth/callback/google"

# ── Optional: email (Resend) ────────────────────────────────────────────────
# RESEND_API_KEY=""
# EMAIL_FROM="N5Deal <noreply@your-domain.com>"

# ── Build flags ─────────────────────────────────────────────────────────────
NODE_ENV="production"
NEXT_TELEMETRY_DISABLED=1
