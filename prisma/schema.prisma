generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ownedProjects     Project[]          @relation("ProjectOwner")
  memberships       ProjectMember[]
  contents          GeneratedContent[]
  socialPosts       SocialPost[]       @relation("SocialPostAuthor")
  linkBuildingItems LinkBuildingItem[] @relation("LinkBuildingAuthor")
  seoKeywords       SeoKeyword[]       @relation("SeoKeywordAuthor")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  companyName String
  description String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner         User              @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members       ProjectMember[]
  icps          ICP[]
  contents      GeneratedContent[]
  redFlagWords  RedFlagWord[]
  internalLinks InternalLink[]
  obsidianVaultPath String?
  tags            Tag[]
  platforms       Platform[]
  promptTemplates PromptTemplate[]

  // Marketing OS module
  socialAccounts    SocialAccount[]
  socialPosts       SocialPost[]
  marketingReports  MarketingReport[]
  marketingStrategy MarketingStrategy?
  brands            Brand[]
  linkBuildingItems LinkBuildingItem[]
  seoKeywords       SeoKeyword[]
  companyInfoSections CompanyInfoSection[]
  contentFolders    ContentFolder[]
  correctionMemos   CorrectionMemo[]

  @@index([ownerId])
}

// =============================================================================
// MARKETING OS — content calendar, reports, strategy, brand cards
// Ported from the standalone Alina Marketing OS prototype.
// =============================================================================

model SocialAccount {
  id          String   @id @default(cuid())
  projectId   String
  slug        String   // n5 | bk | ih | db
  name        String
  color       String   // CSS color value (hex or var)
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  posts   SocialPost[]

  @@unique([projectId, slug])
  @@index([projectId])
}

model SocialPost {
  id           String   @id @default(cuid())
  projectId    String
  accountId    String
  type         String   // Article | Company Post | Founder Post | Reel | Thread | Carousel | Text Post | Repost | Story
  title        String
  content      String?  @db.Text
  platforms    String[] // LI Company, LI Founder, Instagram, X/Twitter, Threads, YouTube, Medium, Newsletter, Reddit, Telegram, Website, LinkedIn
  scheduledFor DateTime
  status       String   @default("idea") // idea | wip | done | pub | skip
  postUrl      String?
  notes        String?  @db.Text
  images       Json?    // array of base64 data URLs or asset URLs
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdById  String?

  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  account   SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdBy User?         @relation("SocialPostAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([projectId, scheduledFor])
  @@index([accountId])
}

model MarketingReport {
  id             String   @id @default(cuid())
  projectId      String
  title          String
  periodLabel    String   // "April 2026"
  html           String?  @db.Text
  notes          String?  @db.Text
  notesByChannel Json?    // { instagram, youtube, linkedin, website }
  metrics        Json?    // raw metric numbers per channel
  imgCount       Int      @default(0)
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model MarketingStrategy {
  id                String   @id @default(cuid())
  projectId         String   @unique
  activeBudgetMonth String   @default("april")
  budget            Json?    // { april: { channel: { min, max, actual, purpose } }, ... }
  goals             Json?    // { channel: { metric: { baseline, target, actual, unit, label } } }
  channelDirectives Json?
  // Baseline diagnosis from the Q2 strategy doc — current SEO / Traffic / IG /
  // LinkedIn / Telegram numbers, plus the "system gap" narrative.
  currentState     Json?
  // Q3-Q4 plan: online events sequence, California offline, 4-part Report
  // System, success measurement.
  authorityLayer   Json?
  updatedAt        DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Brand {
  id           String   @id @default(cuid())
  projectId    String
  slug         String   // n5 | bs | ma
  name         String
  tagline      String?
  pitch        String?  @db.Text
  notes        String?  @db.Text
  features     Json?    // string[]
  deliverables Json?    // { id, text, status, priority }[]
  people       Json?    // { id, name, role }[] — global for the workspace
  sortOrder    Int      @default(0)
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, slug])
  @@index([projectId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("member") // member | admin
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ICP {
  id              String   @id @default(cuid())
  projectId       String
  name            String
  industry        String
  companySize     String
  painPoints      String[] // array of pain points
  goals           String[] // array of goals
  demographics    String
  budgetRange     String
  decisionProcess String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project  Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tags     ICPTag[]
  contents GeneratedContentICP[]

  @@index([projectId])
}

// Project-scoped directory of publishing platforms (Medium, LinkedIn, Reddit,
// N5 site, etc.). Each platform carries its own format constraints and a
// prompt fragment that Content Studio injects when this platform is picked
// for a piece of content. Per TT Section 5.
model Platform {
  id             String   @id @default(cuid())
  projectId      String
  name           String                 // "Medium", "LinkedIn", "Reddit"
  slug           String                 // "medium", "linkedin" — used as a stable id
  formatType     String                 // article | post | newsletter | thread | other
  minLength      Int?                   // null = no lower bound
  maxLength      Int?                   // null = no upper bound
  lengthUnit     String   @default("chars")   // "chars" | "words"
  tone           String?  @db.Text
  hashtagRules   String?  @db.Text
  disclaimers    String?  @db.Text
  promptFragment String?  @db.Text      // platform-specific text appended to LLM prompt
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templates PromptTemplate[]

  @@unique([projectId, slug])
  @@index([projectId])
}

// Reusable prompt templates per content type, optionally specialized per
// platform. Content Studio's "Assemble prompt" step picks the most-specific
// template (contentType + platform > contentType only) and renders it with
// dynamic context. Per TT §4.2 + §4.4 — marketers should never write prompts
// from scratch.
model PromptTemplate {
  id              String   @id @default(cuid())
  projectId       String
  name            String
  contentType     String   // 'articles' | 'market-news' | 'newsletter' | 'social' | 'link-building' | (legacy: 'article' | 'catalog' | 'linkedin' | 'telegram')
  platformId      String?  // null = applies to any platform of this contentType
  systemTemplate  String   @db.Text
  userTemplate    String   @db.Text
  variables       String[] // documentation of supported placeholders, e.g. ["topic", "icp", "platform.tone"]
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platform Platform? @relation(fields: [platformId], references: [id], onDelete: SetNull)

  @@unique([projectId, name])
  @@index([projectId, contentType])
  @@index([platformId])
}

// Project-scoped reusable tag. Same tag can be applied to multiple ICPs in the project.
model Tag {
  id        String   @id @default(cuid())
  projectId String
  name      String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  icps    ICPTag[]

  @@unique([projectId, name])
  @@index([projectId])
}

model ICPTag {
  icpId     String
  tagId     String
  createdAt DateTime @default(now())

  icp ICP @relation(fields: [icpId], references: [id], onDelete: Cascade)
  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([icpId, tagId])
  @@index([icpId])
  @@index([tagId])
}

model GeneratedContent {
  id             String   @id @default(cuid())
  projectId      String
  createdById    String
  contentType    String   // article | catalog | linkedin | telegram
  topic          String
  targetAudience String
  keyMessages    String
  tone           String
  generatedBrief String   @db.Text
  briefData      Json?    // Structured SEO brief spec (TZ-style): pageUrl, wordCount, structure[], mainKeywords[], lsiKeywords[], redFlags[], language, uniqueness, etc.
  folderId       String?  // optional ContentFolder — null = uncategorised
  notes          String?  @db.Text // free-form operator notes / review comments — never sent to the LLM
  // Manual status colour the operator sets from the list/detail view —
  // null = no tag, otherwise one of the palette keys (gray, red, orange,
  // amber, emerald, sky, violet). Rendered as a coloured dot next to the
  // title so the operator can spot review-pending / done / blocked
  // items without opening each one.
  colorTag       String?
  createdAt      DateTime @default(now())

  project     Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User                 @relation(fields: [createdById], references: [id], onDelete: Cascade)
  icps        GeneratedContentICP[]
  folder      ContentFolder?       @relation(fields: [folderId], references: [id], onDelete: SetNull)
  annotations ContentAnnotation[]

  @@index([projectId])
  @@index([createdById])
  @@index([contentType])
  @@index([folderId])
}

// Project-level "remembered corrections". Populated automatically when the
// operator clicks Regenerate-from-notes on a content piece — every
// annotation note becomes a memo that gets injected into the system
// prompt of EVERY subsequent generation in this project, so the same
// mistakes don't repeat. Operator can deactivate / delete entries later
// if a rule turns out to be too narrow.
model CorrectionMemo {
  id              String   @id @default(cuid())
  projectId       String
  note            String   @db.Text // the corrective principle
  selectedText    String?  @db.Text // optional excerpt that originally triggered it
  sourceContentId String?  // which GeneratedContent this came from
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// Inline annotation: a comment / correction attached to a specific text
// selection inside a GeneratedContent. The selectedText + contextBefore /
// contextAfter fingerprint lets us re-locate the same span across edits +
// re-renders without storing raw DOM offsets.
model ContentAnnotation {
  id            String   @id @default(cuid())
  contentId     String
  selectedText  String   @db.Text // the text the operator highlighted
  note          String   @db.Text // their note / correction / TODO
  contextBefore String?  @db.Text // up to ~80 chars before the selection
  contextAfter  String?  @db.Text // up to ~80 chars after the selection
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  content GeneratedContent @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
}

// User-defined folders to organise generated content (e.g. by client,
// campaign, jurisdiction, or content batch). Deleting a folder does NOT
// delete its content — folderId is set null (content becomes uncategorised).
model ContentFolder {
  id        String   @id @default(cuid())
  projectId String
  name      String
  color     String?  // optional UI accent (hex or tailwind token)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contents GeneratedContent[]

  @@unique([projectId, name])
  @@index([projectId, sortOrder])
}

// Many-to-many: a piece of generated content can target multiple ICPs.
// Mirrors how a marketing article often serves several personas at once.
model GeneratedContentICP {
  generatedContentId String
  icpId              String
  createdAt          DateTime @default(now())

  generatedContent GeneratedContent @relation(fields: [generatedContentId], references: [id], onDelete: Cascade)
  icp              ICP              @relation(fields: [icpId], references: [id], onDelete: Cascade)

  @@id([generatedContentId, icpId])
  @@index([generatedContentId])
  @@index([icpId])
}

// Project-level dictionary of "red flag" words/phrases to avoid in generated content.
// Examples: AI-cliches ("delve", "у сучасному світі"), forbidden brand terms, compliance traps.
model RedFlagWord {
  id        String   @id @default(cuid())
  projectId String
  word      String
  category  String   @default("ai") // ai | brand | compliance | competitor | other
  severity  String   @default("warn") // warn | block
  reason    String?  // short explanation why it's flagged
  language  String   @default("any") // any | en | uk | ru
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, word, language])
  @@index([projectId])
  @@index([category])
}

// Cached chunk embeddings for incremental sync (Obsidian vaults, user docs,
// project data). `scope` is a namespace like "project:<id>:obsidian" or
// "userdoc:<userId>". `key` identifies the source item (e.g. relative file
// path, ICP id, or uploaded fileName). `fileHash` lets sync skip unchanged
// items without re-calling the embeddings API.
model EmbeddingChunk {
  id          String   @id @default(cuid())
  scope       String
  key         String   @default("")
  fileHash    String
  chunkIndex  Int      @default(0)
  content     String   @db.Text
  embedding   Float[]
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scope])
  @@index([scope, key])
}

// Project-level library of internal links the AI should insert where natural.
// Content Studio merges these with per-brief overrides and injects into the prompt.
model InternalLink {
  id         String   @id @default(cuid())
  projectId  String
  url        String   // /buyer OR https://n5deal.com/buyer
  anchor     String   // primary anchor phrase (suggested display text)
  anchorAlts String[] // optional alternative anchor phrasings the AI may choose from
  context    String?  // when / where to insert this link (hint for AI)
  category   String?  // optional grouping tag: product | blog | landing | resource
  priority   String   @default("nice") // must | nice
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, url])
  @@index([projectId])
}

// =============================================================================
// LINK BUILDING TRACKER — outreach + placements calendar
// =============================================================================

model LinkBuildingItem {
  id             String    @id @default(cuid())
  projectId      String
  title          String    // Short label / topic
  targetSite     String?   // Domain or full site name we are pitching
  contactName    String?
  contactEmail   String?
  anchorText     String?
  destinationUrl String?   // The page on n5deal.com we want linked
  type           String    @default("outreach") // outreach | guest_post | resource | partner | directory | hari | other
  status         String    @default("planned")  // planned | in_progress | published | declined | followup
  scheduledFor   DateTime  // When this activity is planned / executed
  publishedDate  DateTime?
  liveUrl        String?   // Final URL where the link appears
  dr             Int?      // Domain Rating (Ahrefs / similar)
  cost           Float?    // Money spent on this placement
  notes          String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("LinkBuildingAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([projectId, scheduledFor])
  @@index([projectId, status])
}

// =============================================================================
// SEO TRACKER — keyword position tracking
// =============================================================================

model SeoKeyword {
  id               String    @id @default(cuid())
  projectId        String
  keyword          String    // The search query being tracked
  targetUrl        String?   // The page on n5deal.com targeting this keyword
  currentUrl       String?   // The page actually ranking (may differ from target)
  position         Int?      // Current SERP position; null = not in top 100 / unknown
  previousPosition Int?      // Previous position (for delta calculation)
  impressions      Int?      // Latest impressions (e.g., from GSC)
  clicks           Int?      // Latest clicks
  volume           Int?      // Monthly search volume estimate
  difficulty       Int?      // Keyword difficulty 0-100
  cluster          String?   // Topic grouping: EMI, PSP, Crypto, Fintech, etc.
  intent           String    @default("informational") // informational | commercial | transactional | navigational
  locale           String    @default("global")        // global | uk | us | eu | etc.
  isActive         Boolean   @default(true)
  notes            String?   @db.Text
  lastChecked      DateTime? // When position was last measured
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdById      String?

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("SeoKeywordAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([projectId, keyword])
  @@index([projectId, cluster])
  @@index([projectId, position])
}

// =============================================================================
// COMPANY INFO — structured-but-flexible workspace for everything a marketer
// needs to know about the company: about, team, products, key facts, links,
// press, timeline, plus anything pulled from the Obsidian vault.
// =============================================================================

model CompanyInfoSection {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  type        String   @default("about") // about | team | products | facts | links | press | timeline | mission | values | other
  content     String   @db.Text   // markdown
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(false)
  source      String   @default("manual") // manual | obsidian | imported
  sourcePath  String?  // EmbeddingChunk.key when source = obsidian
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
}
